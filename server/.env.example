CHECKPOINT_ENABLED=true
CHECKPOINT_TYPE=postgres
CHECKPOINT_SQLITE_PATH=./data/suvia-checkpoints.sqlite
CHECKPOINT_POSTGRES_URL=postgresql://suvia:suvia_password@localhost:5432/suvia
LOG_LEVEL=info

# 是否启用评分。
SRS_REVIEW_ENABLED=true
# 是否启用自动优化。
SRS_AUTO_OPTIMIZE_ENABLED=true
# 评分达到多少分算通过。
SRS_SCORE_THRESHOLD=85
# 最多优化几轮。
SRS_MAX_OPTIMIZE_ROUNDS=3
# 每轮最低有效提升分数。
SRS_MIN_SCORE_IMPROVEMENT=3

# Optional fallback used when CHECKPOINT_POSTGRES_URL is not set.
# DATABASE_URL=postgresql://suvia:suvia_password@localhost:5432/suvia
